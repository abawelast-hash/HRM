# ============================================
# ShamIn Environment Configuration Template
# ============================================
# نسخ هذا الملف إلى .env وملء القيم الفعلية
# cp .env.example .env

# ===== PostgreSQL Database =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shamin_db
POSTGRES_USER=shamin_user
POSTGRES_PASSWORD=changeme_strong_password_here

# ===== InfluxDB (Time-series Database) =====
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme_influx_token_here
INFLUXDB_ORG=shamin_org
INFLUXDB_BUCKET=exchange_rates
INFLUXDB_PASSWORD=changeme_influx_password_here

# ===== Redis (Message Queue) =====
REDIS_URL=redis://redis:6379/0

# ===== MinIO (Object Storage) =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=changeme_minio_access_key
MINIO_SECRET_KEY=changeme_minio_secret_key

# ===== Telegram API (اختياري - للجمع من تلغرام) =====
# احصل عليها من: https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_BOT_TOKEN=

# ===== Email/SMTP (اختياري - للتنبيهات) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_TO=admin@example.com

# ===== External APIs (اختياري) =====
# Alpha Vantage (للذهب، نفط، DXY)
ALPHA_VANTAGE_API_KEY=

# Yahoo Finance (بديل)
YAHOO_FINANCE_KEY=

# ===== Application Settings =====
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=False
SECRET_KEY=changeme_very_long_random_secret_key_here

# ===== Advanced Settings (متقدم - اترك افتراضي) =====
# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Workers
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_MAX_TASKS_PER_CHILD=100

# Dashboard
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# API
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=1

# ===== Notes =====
# 1. غيّر جميع كلمات المرور "changeme_*" بقيم قوية
# 2. احفظ هذا الملف في مكان آمن - لا تشاركه
# 3. أضف .env إلى .gitignore (مضاف مسبقاً)
